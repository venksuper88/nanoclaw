{
  "goldenHeadline": {
    "fontFamily": "'Noto Sans', sans-serif",
    "fontWeight": "600",
    "fontSize": "50px",
    "letterSpacing": "-5px",
    "background": "linear-gradient(to bottom, #FFF8CC 0%, #FFE066 25%, #ffb007 55%, #ff8e07 100%)",
    "WebkitBackgroundClip": "text",
    "WebkitTextFillColor": "transparent",
    "backgroundClip": "text",
    "textTransform": "uppercase",
    "textAlign": "center",
    "lineHeight": "1.08",
    "WebkitTextStroke": "1.8px #9e5001",
    "filter": "drop-shadow(0 5px 0 #5A2E00) drop-shadow(0 5px 12px rgba(0,0,0,0.55))"
  },
  "whiteButtonText": {
    "fontFamily": "'Noto Sans', sans-serif",
    "fontWeight": "900",
    "color": "#ffffff",
    "whiteSpace": "nowrap",
    "textAlign": "center",
    "textShadow": "0 3px 6px rgba(0,0,0,0.3)"
  }
}